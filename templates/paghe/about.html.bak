{% extends "base.html" %}
{% block breadcrumb %}
<nav aria-label="Breadcrumb" class="breadcrumb-nav">
    <ol class="breadcrumb-list">
        <li class="breadcrumb-item"><a href="{% url 'dashboard' %}">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="{% url 'backup_page' %}">Sistema</a></li>
        <li class="breadcrumb-item active" aria-current="page">About</li>
    </ol>
</nav>
{% endblock %}
{% block content %}
<style>
  .about-header {
    background: linear-gradient(135deg, #1a1b1e 0%, #0E0F11 100%);
    border: 1px solid #27282D;
    border-radius: 16px;
    padding: 40px;
    text-align: center;
    margin-bottom: 24px;
  }
  .about-logo {
    width: 100px;
    height: 100px;
    object-fit: contain;
    border-radius: 20px;
    margin-bottom: 16px;
  }
  .about-logo-placeholder {
    width: 100px;
    height: 100px;
    background: #5E6AD2;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px auto;
  }
  .about-logo-placeholder i { font-size: 48px; color: white; }
  .about-title {
    font-size: 28px;
    font-weight: 700;
    color: white;
    margin-bottom: 4px;
  }

  .about-version {
    color: #8A8F98;
    font-size: 14px;
    margin-bottom: 12px;
  }
  .about-desc {
    color: #a1a5ab;
    max-width: 600px;
    margin: 0 auto;
    font-size: 14px;
    line-height: 1.6;
  }
  .about-section {
    background: #0E0F11;
    border: 1px solid #27282D;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 20px;
  }
  .about-section h4 {
    font-size: 16px;
    font-weight: 600;
    color: white;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .about-section h4 i { color: #5E6AD2; font-size: 18px; }
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 8px;
  }
  .tech-item {
    background: #17181C;
    border: 1px solid #27282D;
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: border-color 0.2s;
  }
  .tech-item:hover { border-color: #5E6AD2; }
  .tech-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
    background: #1c1c1f;
    overflow: hidden;
  }
  .tech-icon img { width: 18px; height: 18px; object-fit: contain; filter: brightness(1.2); }
  .tech-item .tech-name { font-size: 13px; font-weight: 600; color: white; }
  .tech-item .tech-ver { font-size: 11px; color: #8A8F98; }
  .credit-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid #1c1c1f;
    font-size: 13px;
  }
  .credit-line:last-child { border-bottom: none; }
  .credit-line span:first-child { color: #a1a5ab; }
  .credit-line span:last-child { color: white; font-weight: 500; }
</style>

<div class="about-header">
  {% if opzioni and opzioni.logo %}
    <img src="{{ opzioni.logo.url }}" alt="Logo" class="about-logo">
  {% else %}
    <div class="about-logo-placeholder"><i class="bi bi-cpu-fill"></i></div>
  {% endif %}
  <div class="about-title">{{ opzioni.nome_programma|default:"GESTIONE PAGHE" }}
    <button class="btn btn-sm" title="Aiuto" data-bs-toggle="modal" data-bs-target="#helpModal" style="background:transparent;color:#8A8F98;border:1px solid #333;border-radius:50%;width:30px;height:30px;padding:0;font-size:14px;font-weight:700;line-height:1;flex-shrink:0;vertical-align:middle;margin-left:8px;"><i class="bi bi-question-lg"></i></button>
  </div>
  <div class="about-version">v{{ opzioni.versione_programma|default:"1.1" }}</div>
  <div class="about-desc">
    Software per la gestione di contratti di lavoro domestico, buste paga,
    adempimenti INPS, PagoPA e reportistica professionale.
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="about-section">
      <h4><i class="bi bi-stack"></i> Tecnologie</h4>
      <div class="tech-grid">
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/python" alt="Python"></div>
          <div><div class="tech-name">Python</div><div class="tech-ver">3.13</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/django" alt="Django"></div>
          <div><div class="tech-name">Django</div><div class="tech-ver">6.0</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/sqlite" alt="SQLite"></div>
          <div><div class="tech-name">SQLite</div><div class="tech-ver">3.x</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon" style="background:#dc2626;"><i class="bi bi-filetype-pdf" style="font-size:16px;color:white;"></i></div>
          <div><div class="tech-name">ReportLab</div><div class="tech-ver">4.5</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon" style="background:#5E6AD2;"><i class="bi bi-filetype-pdf" style="font-size:16px;color:white;"></i></div>
          <div><div class="tech-name">xhtml2pdf</div><div class="tech-ver">—</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/chartdotjs" alt="Chart.js"></div>
          <div><div class="tech-name">Chart.js</div><div class="tech-ver">4.x</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/bootstrap" alt="Bootstrap"></div>
          <div><div class="tech-name">Bootstrap</div><div class="tech-ver">5.x</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/tinymce" alt="TinyMCE"></div>
          <div><div class="tech-name">TinyMCE</div><div class="tech-ver">7.x</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/playwright" alt="Playwright"></div>
          <div><div class="tech-name">Playwright</div><div class="tech-ver">1.60</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon"><img src="https://cdn.simpleicons.org/selenium" alt="Selenium"></div>
          <div><div class="tech-name">Selenium</div><div class="tech-ver">4.44</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon" style="background:#107C41;"><i class="bi bi-file-earmark-spreadsheet" style="font-size:16px;color:white;"></i></div>
          <div><div class="tech-name">OpenPyXL</div><div class="tech-ver">3.1</div></div>
        </div>
        <div class="tech-item">
          <div class="tech-icon" style="background:#f59e0b;"><i class="bi bi-clock" style="font-size:16px;color:white;"></i></div>
          <div><div class="tech-name">APScheduler</div><div class="tech-ver">3.11</div></div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="about-section">
      <h4><i class="bi bi-people"></i> Crediti</h4>
      <div class="credit-line">
        <span>Sviluppo e progettazione</span>
        <span>Corongiu Gabriele</span>
      </div>
      <div class="credit-line">
        <span>Admin</span>
        <span>Corongiu Gabriele</span>
      </div>
      <div class="credit-line">
        <span>Framework backend</span>
        <span>Django 6.0</span>
      </div>
      <div class="credit-line">
        <span>Generazione PDF</span>
        <span>ReportLab 4.5</span>
      </div>
      <div class="credit-line">
        <span>UI Framework</span>
        <span>Bootstrap 5 + Bootstrap Icons</span>
      </div>
      <div class="credit-line">
        <span>Grafici dashboard</span>
        <span>Chart.js</span>
      </div>
      <div class="credit-line">
        <span>Editor di testo</span>
        <span>TinyMCE</span>
      </div>
      <div class="credit-line">
        <span>Automazione web</span>
        <span>Playwright · Selenium</span>
      </div>
      <div class="credit-line">
        <span>Backup automatici</span>
        <span>APScheduler</span>
      </div>
      <div class="credit-line">
        <span>Database</span>
        <span>SQLite</span>
      </div>
    </div>

    <div class="about-section">
      <h4><i class="bi bi-info-circle"></i> Dipendenze Python</h4>
      <div style="max-height:200px;overflow-y:auto;font-size:12px;color:#8A8F98;font-family:monospace;">
        APScheduler 3.11 · Chart.js · Chromedriver Autoinstaller · Django 6.0<br>
        Django-Import-Export · Django Jazzmin · Django Unfold · OpenPyXL<br>
        Playwright 1.60 · PyMuPDF · PyAutoGUI · pywin32 · pywinauto<br>
        ReportLab 4.5 · Selenium 4.44 · TinyMCE · xhtml2pdf · e molti altri
      </div>
    </div>
  </div>
</div>

<!-- Help Modal -->
<div class="modal fade" id="helpModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
    <div class="modal-content" style="background:#1a1a1e;border:1px solid #27282D;border-radius:14px;">
      <div class="modal-header" style="border-bottom:1px solid #27282D;padding:14px 18px;">
        <h5 class="modal-title" style="font-size:15px;font-weight:700;color:#EDEDED;">
          <i class="bi bi-question-circle me-2" style="color:#5E6AD2;"></i>Aiuto — About
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="padding:18px;font-size:13px;color:#8A8F98;line-height:1.6;">
        <p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Cos'è questa pagina</b><br>
        Pagina informativa con i dettagli del software: versione installata, tecnologia utilizzata, librerie e framework. Utile per verificare la versione corrente e le dipendenze del sistema.</p>

        <p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Informazioni visualizzate</b><br>
        <b>Nome e versione</b> — nome del programma e versione corrente configurata nelle Impostazioni.<br>
        <b>Tecnologie</b> — stack tecnologico: Django 6.0, ReportLab, SQLite, Playwright, Selenium, ecc.<br>
        <b>Dipendenze Python</b> — elenco completo dei pacchetti Python utilizzati dal gestionale.</p>

        <p style="margin-bottom:0;"><b style="color:#EDEDED;font-size:14px;">Note</b><br>
        La versione del programma può essere modificata dalla pagina <b>Impostazioni</b>. Le dipendenze elencate sono quelle installate nell'ambiente Python corrente.</p>
      </div>
    </div>
  </div>
</div>
{% endblock %}