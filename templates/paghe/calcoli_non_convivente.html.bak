{% extends 'base.html' %}
{% load static %}

{% block extra_css %}
<style>
@media print {
    @page { margin: 15mm 18mm; size: A4 portrait; }
    * { box-shadow: none !important; text-shadow: none !important; }
    body { background: white !important; color: #111 !important; font-family: 'Segoe UI', 'Arial', sans-serif !important; }
    .sidebar, .nav-group-divider, .nav-group, .sidebar-footer,
    #fContratto, #fMese, #fAnno, #btnPrev, #btnNext, #btnPdf, #sostituzioneToggle,
    .navbar, .main-header, footer, .no-print { display: none !important; }
    .main-content, .container-fluid, .col-md-6, .col-md-3, .col-md-4, .row { margin: 0 !important; padding: 0 !important; max-width: 100% !important; width: 100% !important; float: none !important; }
    #bustaContainer { display: block !important; }
    #bustaEmpty { display: none !important; }
    #bustaContent > div { border: none !important; border-radius: 0 !important; padding: 0 !important; }
    #bustaContent [style*="background:#17181C"] { background: white !important; border: none !important; }
    #bustaContent [style*="background:rgba(16,185,129,0.06)"] { background: #f0fdf4 !important; border: 1px solid #86efac !important; }
    #bustaContent [style*="border-bottom:1px solid #27282D"] { border-bottom: 1px solid #e5e7eb !important; }
    #bustaContent [style*="rgba(255,255,255,0.04)"] { border-bottom: 1px solid #f0f0f0 !important; }
    #bustaContent [style*="color:#EDEDED"] { color: #111 !important; }
    #bustaContent [style*="color:#8A8F98"] { color: #666 !important; }
    #bustaContent [style*="color:#10b981"] { color: #059669 !important; }
    #bustaContent [style*="color:#34d399"] { color: #059669 !important; }
    #bustaContent [style*="color:#f59e0b"] { color: #d97706 !important; }
    #bustaContent [style*="color:#f87171"] { color: #dc2626 !important; }
    #bustaContent [style*="color:#5E6AD2"] { color: #4f46e5 !important; }
    #bustaContent [style*="border-top:2px solid rgba(52,211,153,0.3)"] { border-top: 2px solid #059669 !important; }
    #bustaContent [style*="border-top:2px solid rgba(245,158,11,0.3)"] { border-top: 2px solid #d97706 !important; }
    #bustaContent [style*="border-top:2px solid rgba(248,113,113,0.3)"] { border-top: 2px solid #dc2626 !important; }
    #bustaContent [style*="rgba(16,185,129,0.15)"] { border-color: #86efac !important; }
    #bustaContent .row { display: flex !important; flex-wrap: wrap !important; }
    #bustaContent .col-md-6 { width: 50% !important; float: left !important; padding: 0 10px !important; box-sizing: border-box !important; }
    [style*="margin-top:20px"] { clear: both !important; }
    [style*="background:rgba(94,106,210,0.15)"], [style*="background:rgba(255,255,255,0.05)"] { background: #f5f5f5 !important; border-color: #ddd !important; }
    h1, .h3, [class*="fw-bold mb-1"] { font-size: 14pt !important; color: #111 !important; }
    .text-secondary { display: none !important; }
    .d-flex.justify-content-between.mb-3 { display: none !important; }
    img, svg, .bi, i { display: none !important; }
    [class*="bi-"] { display: none !important; }
    #bustaContent [style*="font-size:10px;text-transform:uppercase"] { font-size: 7pt !important; letter-spacing: 0.05em !important; }
    #bustaContent [style*="font-size:11px;text-transform:uppercase"] { font-size: 9pt !important; }
    #bustaContent [style*="font-size:13px;font-weight:600"] { font-size: 9pt !important; }
    #bustaContent [style*="font-size:12px"] { font-size: 8pt !important; }
    #bustaContent [style*="font-size:15px;font-weight:800"] { font-size: 10pt !important; }
    #bustaContent [style*="font-size:16px;font-weight:800"] { font-size: 11pt !important; }
    #bustaContent [style*="font-size:20px;font-weight:800"] { font-size: 12pt !important; }
    [style*="border-radius:14px"] { border-radius: 0 !important; }
    [style*="border-radius:12px"] { border-radius: 4px !important; }
    [style*="padding:20px 24px"] { padding: 10px 0 !important; }
    [style*="padding:16px"] { padding: 12px !important; }
}

/* Toggle switch */
.toggle-switch {
    position: relative;
    display: inline-block;
    width: 42px;
    height: 22px;
    flex-shrink: 0;
}
.toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
    position: absolute;
}
.toggle-switch .toggle-slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #555;
    border: 1px solid #666;
    border-radius: 22px;
    transition: 0.3s;
    width: auto;
    height: auto;
    margin-left: 0;
}
.toggle-switch .toggle-slider::after {
    display: none;
}
.toggle-switch .toggle-slider::before {
    position: absolute;
    content: "";
    height: 16px;
    width: 16px;
    left: 3px;
    bottom: 1px;
    background-color: #ccc;
    border-radius: 50%;
    transition: 0.3s;
}
.toggle-switch input:checked + .toggle-slider {
    background-color: rgba(168,85,247,0.3);
    border-color: #a855f7;
}
.toggle-switch input:checked + .toggle-slider::before {
    transform: translateX(20px);
    background-color: #a855f7;
}
.toggle-switch.conv-toggle-small input:checked + .toggle-slider {
    background-color: rgba(52,211,153,0.3);
    border-color: #34d399;
}
.toggle-switch.conv-toggle-small input:checked + .toggle-slider::before {
    background-color: #34d399;
}
.toggle-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    user-select: none;
}
</style>
{% endblock %}

{% block breadcrumb %}
<nav aria-label="Breadcrumb" class="breadcrumb-nav">
    <ol class="breadcrumb-list">
        <li class="breadcrumb-item"><a href="{% url 'dashboard' %}">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="{% url 'calcoli_list' %}">Busta Paga</a></li>
        <li class="breadcrumb-item active" aria-current="page">Busta Non Convivente</li>
    </ol>
</nav>
{% endblock %}

{% block content %}
{% block search_bar %}{% endblock %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 fw-bold mb-1"><i class="bi bi-person me-2"></i>BUSTA NON CONVIVENTE</h1>
        <p class="text-secondary small mb-0">Calcolo busta paga per lavoratori non conviventi.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <button class="btn btn-sm" onclick="salvaBusta()" style="background:rgba(245,158,11,0.15);color:#f59e0b;border:1px solid rgba(245,158,11,0.25);border-radius:8px;padding:8px 16px;font-size:12px;font-weight:600;" id="btnSalvaBusta" disabled>
            <i class="bi bi-save me-1"></i> SALVA BUSTA
        </button>
        <button class="btn btn-sm" onclick="vaiContratto()" style="background:rgba(16,185,129,0.15);color:#10b981;border:1px solid rgba(16,185,129,0.25);border-radius:8px;padding:8px 16px;font-size:12px;font-weight:600;" id="btnContratto" disabled>
            <i class="bi bi-box-arrow-up-right me-1"></i> VAI AL CONTRATTO
        </button>
        <button class="btn btn-sm" onclick="apriCcnlOcchio()" style="background:rgba(94,106,210,0.12);color:#818cf8;border:1px solid rgba(94,106,210,0.2);border-radius:8px;padding:8px 14px;font-size:12px;font-weight:600;" id="btnCcnlOcchio" disabled>
            <i class="bi bi-eye me-1"></i> CCNL
        </button>
        <a href="{% url 'buste_archivio' %}" class="btn btn-sm" style="background:rgba(94,106,210,0.1);color:#5E6AD2;border:1px solid rgba(94,106,210,0.2);border-radius:8px;padding:8px 14px;font-size:12px;font-weight:600;text-decoration:none;">
            <i class="bi bi-journal-text me-1"></i> Archivio Buste
        </a>
        <button class="btn btn-sm" title="Aiuto" data-bs-toggle="modal" data-bs-target="#helpModal" style="background:transparent;color:#8A8F98;border:1px solid #333;border-radius:50%;width:30px;height:30px;padding:0;font-size:14px;font-weight:700;line-height:1;flex-shrink:0;vertical-align:middle;margin-left:8px;"><i class="bi bi-question-lg"></i></button>
        <div class="d-flex align-items-center" style="font-size:12px;color:#8A8F98;gap:6px;">
            <span>Sostituzione</span>
            <label class="toggle-switch">
                <input type="checkbox" id="sostituzioneToggle" onchange="toggleSostituzione()">
                <span class="toggle-slider"></span>
            </label>
        </div>
        <button class="btn btn-sm" onclick="downloadPdf()" style="background:rgba(94,106,210,0.15);color:#5E6AD2;border:1px solid rgba(94,106,210,0.25);border-radius:8px;padding:8px 16px;font-size:12px;font-weight:600;" id="btnPdf" disabled>
            <i class="bi bi-file-pdf me-1"></i> PDF
        </button>
        <button class="btn btn-sm" onclick="stampaBustaCalcolo(this)" style="background:#ffc107;color:#000;border:none;border-radius:8px;padding:8px 16px;font-size:12px;font-weight:600;" id="btnStampa" disabled>
            <i class="bi bi-printer me-1"></i> STAMPA
        </button>
    </div>
</div>

<div class="p-3 mb-3" style="background:#17181C;border:1px solid #27282D;border-radius:14px;">
    <div class="row g-3 align-items-end">
        <div class="col-md-6">
            <label class="mb-1 fw-bold" style="font-size:10px;text-transform:uppercase;letter-spacing:0.04em;color:#8A8F98;">Contratto</label>
            <select id="fContratto" class="form-control" onchange="selezionaContratto()" style="background-color:#09090B;border:1px solid #27282D;color:#ffffff;font-size:13px;padding:8px 12px;border-radius:8px;">
                <option value="">— Seleziona un contratto —</option>
                {% for c in contratti %}
                <option value="{{ c.pk }}" {% if c.pk == contratto_pk %}selected{% endif %}>{{ c.datore.nome_cognome }} — {{ c.lavoratore.nome_cognome }} ({{ c.parametri_minimi.livello.codice|default:"?" }})</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-2">
            <label class="mb-1 fw-bold" style="font-size:10px;text-transform:uppercase;letter-spacing:0.04em;color:#8A8F98;">Mese</label>
            <select id="fMese" class="form-control" onchange="selezionaContratto()" style="background-color:#09090B;border:1px solid #27282D;color:#ffffff;font-size:13px;padding:8px 12px;border-radius:8px;">
                {% for m in mesi_range %}
                <option value="{{ m|stringformat:'02d' }}" {% if m == mese %}selected{% endif %}>{{ m|stringformat:'02d' }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-2">
            <label class="mb-1 fw-bold" style="font-size:10px;text-transform:uppercase;letter-spacing:0.04em;color:#8A8F98;">Anno</label>
            <select id="fAnno" class="form-control" onchange="selezionaContratto()" style="background-color:#09090B;border:1px solid #27282D;color:#ffffff;font-size:13px;padding:8px 12px;border-radius:8px;">
                {% for a in anni_range %}
                <option value="{{ a }}" {% if a == anno %}selected{% endif %}>{{ a }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-2 d-flex gap-1">
            <button class="btn btn-sm flex-fill" onclick="navContratto(-1)" style="background:rgba(255,255,255,0.05);border:1px solid #27282D;border-radius:8px;padding:8px;color:#EDEDED;font-size:13px;" disabled id="btnPrev"><i class="bi bi-chevron-left"></i></button>
            <button class="btn btn-sm flex-fill" onclick="navContratto(1)" style="background:rgba(255,255,255,0.05);border:1px solid #27282D;border-radius:8px;padding:8px;color:#EDEDED;font-size:13px;" disabled id="btnNext"><i class="bi bi-chevron-right"></i></button>
        </div>
    </div>
</div>

<div class="p-2 mb-3" style="background:rgba(255,255,255,0.02);border:1px solid #27282D;border-radius:10px;display:none;" id="controlsContainer">
    <div class="d-flex align-items-center flex-wrap gap-3" style="font-size:11px;color:#8A8F98;">
        <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.04em;font-weight:700;color:#5C5F66;">Vitto/Alloggio</span>
        <span class="toggle-item">
            <span>Pranzo</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="inclPranzo" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>Cena</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="inclCena" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>Alloggio</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="inclAlloggio" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <div class="d-flex align-items-center gap-1">
            <span>Giorni:</span>
            <input type="number" id="giorniConv" value="26" min="1" max="31" onchange="selezionaContratto()" style="width:50px;background:#09090B;border:1px solid #27282D;color:#EDEDED;padding:4px 6px;border-radius:6px;font-size:12px;text-align:center;">
        </div>
        <div id="convRiepilogo" style="font-size:10px;color:#5C5F66;font-style:italic;"></div>

        <span style="width:1px;height:20px;background:#27282D;"></span>

        <span style="font-size:9px;text-transform:uppercase;letter-spacing:0.04em;font-weight:700;color:#5C5F66;">Indennità</span>
        <span class="toggle-item">
            <span>Funzione</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="indFunzione" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>Bambini &lt;6</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="indBambini6" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>Più Assistiti</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="indPiuAssistiti" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>Cert. Qualità</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="indCertQualita" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>

        <span style="width:1px;height:20px;background:#27282D;"></span>

        <span class="toggle-item">
            <span>Scatti Anzianità</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="toggleScatti" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>TFR</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="rateoTfr" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>13ª</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="rateo13ma" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>Ferie</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="rateoFerie" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>
        <span class="toggle-item">
            <span>Festivi</span>
            <label class="toggle-switch conv-toggle-small">
                <input type="checkbox" id="rateoFestivi" onchange="selezionaContratto()">
                <span class="toggle-slider"></span>
            </label>
        </span>

        <button onclick="resetToggles()" title="Ripristina valori contratto" style="background:transparent;border:1px solid #5E6AD2;color:#5E6AD2;border-radius:6px;padding:3px 10px;font-size:11px;cursor:pointer;margin-left:auto;"><i class="bi bi-arrow-counterclockwise"></i> Reset</button>
    </div>
</div>

<div id="bustaContainer" style="display:none;">
    <div id="bustaEsistenteWarning" role="alert" style="display:none;padding:10px 14px;margin-bottom:12px;background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.3);border-radius:10px;color:#ef4444;font-size:12px;font-weight:600;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> Busta paga già salvata per questo periodo. Clicca <strong>SALVA BUSTA</strong> per sovrascriverla.
    </div>
    <div id="bustaLoading" class="text-center py-5" style="display:none;">
        <div class="spinner-border" style="color:#5E6AD2;" role="status"></div>
        <div class="mt-2 text-secondary small">Calcolo in corso...</div>
    </div>
    <div id="bustaContent"></div>
</div>

<div id="bustaEmpty" class="text-center py-5" style="color:#5C5F66;">
    <i class="bi bi-person fs-1 d-block mb-3" style="color:#27282D;"></i>
    <div>Seleziona un contratto per visualizzare la busta paga non convivente.</div>
</div>
<!-- HELP MODAL -->
<div class="modal fade" id="helpModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content" style="background:#1a1a1e;border:1px solid #27282D;border-radius:14px;">
      <div class="modal-header" style="border-bottom:1px solid #27282D;padding:14px 18px;">
        <h5 class="modal-title" style="font-size:15px;font-weight:700;color:#EDEDED;"><i class="bi bi-question-circle me-2" style="color:#5E6AD2;"></i>Aiuto — Busta Non Convivente</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="padding:18px;font-size:13px;color:#8A8F98;line-height:1.6;">
        <p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Cos'è questa pagina</b><br>
Qui puoi calcolare la busta paga mensile di un collaboratore domestico <b>non convivente</b>, cioè che NON vive nella stessa casa del datore di lavoro. Questo è il caso più comune: la colf o il badante viene a ore e torna a casa sua.<br><br>
Il calcolo parte dalla <b>paga oraria</b> moltiplicata per le <b>ore mensili</b> previste dal contratto. A differenza della pagina "Busta Standard" (che usa il budget dei progetti regionali e applica il prorating), qui non c'è un budget limite da rispettare: il lavoratore prende esattamente paga_oraria × ore.</p>

<p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Come si usa — 3 passi</b><br>
<b>1.</b> Scegli un contratto dal menu a tendina.<br>
<b>2.</b> Regola le opzioni: toggle Sostituzione (Art. 14), ratei, indennità, scatti, convivenza (vitto/alloggio forfettario).<br>
<b>3.</b> Leggi la busta paga: Lordo, Contributi INPS, Trattenute (vitto/alloggio, ratei accantonati), Netto.</p>

<p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Sostituzione (Art. 14 comma 9 del CCNL)</b><br>
Se attivi il toggle "Sostituzione", il sistema usa la <b>retribuzione oraria di sostituzione</b> (Tabella G del CCNL) invece della normale paga base. Questa è più alta della paga base normale.<br><br>
Cosa cambia:<br>
— La paga base viene sostituita dalla <b>retribuzione di sostituzione</b> (es. invece di €6,00/h si usa €7,50/h).<br>
— Non si applica il prorating (il prorata è sempre 1,0 — non c'è limite di budget).<br>
— Il calcolo diventa: retribuzione_sostituzione × ore_mensili.<br><br>
<b>Attenzione:</b> la sostituzione è un istituto diverso dalla "Sostituzione Malattia" che trovi nell'apposita pagina. Qui si tratta di un lavoratore che sostituisce temporaneamente un altro con una paga maggiorata.</p>

<p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Ratei — TFR, 13ª, Ferie, Festivi</b><br>
Per ogni rateo hai 3 scelte:<br>
<span style="color:#34d399;">✓ Incluso nel lordo</span> — Pagato in busta ogni mese.<br>
<span style="color:#f59e0b;">⟳ Accantonato</span> — Calcolato ma trattenuto per liquidazione futura (TFR a fine rapporto, 13ª a dicembre, ferie non godute).<br>
<span style="color:#5C5F66;">✕ Disabilitato</span> — Non viene calcolato.<br><br>
<b>TFR:</b> la liquidazione. Si accumua mese per mese e viene pagata quando il rapporto finisce.<br>
<b>13ª:</b> la tredicesima, pagata a dicembre.<br>
<b>Ferie:</b> giorni di ferie maturati e non goduti.<br>
<b>Festivi:</b> festività non godute (Pasqua, 1° Maggio, etc.).</p>

<p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Indennità e Scatti di Anzianità</b><br>
Le <b>indennità</b> sono importi mensili aggiuntivi previsti dal CCNL:<br>
— Indennità di funzione (per ruoli con responsabilità).<br>
— Indennità bambini sotto i 6 anni (se assiste minori).<br>
— Indennità più assistiti (se assiste più persone).<br>
— Indennità certificazione qualità.<br><br>
Gli <b>scatti di anzianità</b> sono aumenti ogni 2 anni di servizio presso lo stesso datore.</p>

<p style="margin-bottom:14px;"><b style="color:#EDEDED;font-size:14px;">Convivenza — Vitto e Alloggio Forfettario</b><br>
Anche per i non conviventi puoi attivare vitto e alloggio (es. se il lavoratore mangia a casa del datore).<br>
— Pranzo: €2,33/gg — Cena: €2,33/gg — Alloggio: €2,00/gg.<br>
I giorni sono di default 26 (dal lunedì al sabato). L'importo viene detratto dal netto.</p>

<p style="margin-bottom:0;"><b style="color:#EDEDED;font-size:14px;">Contributi INPS</b><br>
I contributi INPS si calcolano sulle <b>ore INPS</b>, che sono le ore mensili arrotondate per eccesso all'intero superiore. Per esempio, se il contratto prevede 108,33 ore al mese, le ore INPS sono 109.<br><br>
L'aliquota contributiva dipende dalla <b>fascia oraria settimanale</b>:<br>
— <b>SOPRA la soglia</b> (24 ore settimanali o più): aliquota piena.<br>
— <b>SOTTO la soglia</b> (meno di 24 ore settimanali): aliquota ridotta.<br><br>
A questi si aggiunge la <b>quota cassa/ente bilaterale</b> (es. EBINCOLF, CAD, etc.), un piccolo contributo aggiuntivo calcolato sulle stesse ore INPS.</p>

        <p style="margin-bottom:0;"><b style="color:#EDEDED;font-size:14px;">Salva Busta e Archivio</b><br>
        <b>SALVA BUSTA</b> — salva il calcolo corrente come record permanente nell'archivio buste paga. Puoi sovrascrivere una busta già salvata per lo stesso periodo cliccando di nuovo.<br>
        <b>Archivio Buste</b> — consulta tutte le buste paga salvate, filtrale per tipo, datore, lavoratore, mese e anno. Da lì puoi cambiare lo stato (bozza/approvata/archiviata) ed eliminare record.</p>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
var contrattiList = [];
var currIdx = -1;

(function() {
    var sel = document.getElementById('fContratto');
    contrattiList = [];
    for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value) contrattiList.push(sel.options[i].value);
    }
})();

window.toggleSostituzione = function() {
    var showConv = document.getElementById('sostituzioneToggle').checked;
    document.getElementById('controlsContainer').style.display = showConv ? 'block' : 'none';
    selezionaContratto();
};

window.selezionaContratto = function() {
    var sel = document.getElementById('fContratto');
    var pk = sel.value;
    if (!pk) {
        document.getElementById('bustaContainer').style.display = 'none';
        document.getElementById('bustaEmpty').style.display = 'block';
        document.getElementById('btnPrev').disabled = true;
        document.getElementById('btnNext').disabled = true;
        document.getElementById('btnPdf').disabled = true;
        document.getElementById('btnContratto').disabled = true;
        document.getElementById('btnSalvaBusta').disabled = true;
        currIdx = -1;
        return;
    }
    currIdx = contrattiList.indexOf(pk);
    document.getElementById('btnPrev').disabled = currIdx <= 0;
    document.getElementById('btnNext').disabled = currIdx >= contrattiList.length - 1;
    document.getElementById('bustaEmpty').style.display = 'none';
    document.getElementById('bustaContainer').style.display = 'block';
    document.getElementById('bustaLoading').style.display = 'block';
    document.getElementById('bustaContent').innerHTML = '';
    document.getElementById('btnPdf').disabled = true;
    document.getElementById('btnPdf').dataset.pk = pk;
    document.getElementById('btnSalvaBusta').disabled = false;
    document.getElementById('btnSalvaBusta').dataset.pk = pk;
    document.getElementById('btnContratto').disabled = false;
    document.getElementById('btnContratto').dataset.pk = pk;
    document.getElementById('controlsContainer').style.display = 'block';
    var mese = document.getElementById('fMese').value;
    var anno = document.getElementById('fAnno').value;
    var sost = document.getElementById('sostituzioneToggle').checked ? '1' : '0';
    var inclPranzo = document.getElementById('inclPranzo').checked ? '1' : '0';
    var inclCena = document.getElementById('inclCena').checked ? '1' : '0';
    var inclAlloggio = document.getElementById('inclAlloggio').checked ? '1' : '0';
    var giorniConv = document.getElementById('giorniConv').value;
    var indFn = document.getElementById('indFunzione').checked ? '1' : '0';
    var indB6 = document.getElementById('indBambini6').checked ? '1' : '0';
    var indPA = document.getElementById('indPiuAssistiti').checked ? '1' : '0';
    var indCQ = document.getElementById('indCertQualita').checked ? '1' : '0';
    var scatti = document.getElementById('toggleScatti').checked ? '1' : '0';
    var rateo13ma = document.getElementById('rateo13ma').checked ? '1' : '0';
    var rateoFerie = document.getElementById('rateoFerie').checked ? '1' : '0';
    var rateoFestivi = document.getElementById('rateoFestivi').checked ? '1' : '0';
    var rateoTfr = document.getElementById('rateoTfr').checked ? '1' : '0';
    fetch('/ajax/calcola-busta-non-convivente/' + pk + '/?mese=' + mese + '&anno=' + anno + '&sostituzione=' + sost + '&incl_pranzo=' + inclPranzo + '&incl_cena=' + inclCena + '&incl_alloggio=' + inclAlloggio + '&giorni_conv=' + giorniConv + '&ind_funzione=' + indFn + '&ind_bambini_6=' + indB6 + '&ind_piu_assistiti=' + indPA + '&ind_cert_qualita=' + indCQ + '&scatti=' + scatti + '&rateo_tfr=' + rateoTfr + '&rateo_13ma=' + rateo13ma + '&rateo_ferie=' + rateoFerie + '&rateo_festivi=' + rateoFestivi, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
    })
    .then(function(r) {
        if (!r.ok) throw new Error('Errore server: ' + r.status + ' ' + r.statusText);
        return r.json();
    })
    .then(function(d) {
        document.getElementById('bustaLoading').style.display = 'none';
        if (d.errore) {
            document.getElementById('bustaContent').innerHTML = '<div class="p-4 text-center" style="color:#f87171;background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.2);border-radius:14px;"><i class="bi bi-exclamation-triangle me-2"></i>' + d.errore + '</div>';
            return;
        }
        renderBustaNonConvivente(d);
        document.getElementById('btnPdf').disabled = false;
        window._lastStdData = d;
        var warn = document.getElementById('bustaEsistenteWarning');
        if (warn) warn.style.display = d.busta_esistente ? 'block' : 'none';
        // Pre-imposta toggle dal contratto al primo caricamento
        if (window._lastStdPk !== pk) {
            document.getElementById('inclPranzo').checked = !!d.contratto_paga_pranzo;
            document.getElementById('inclCena').checked = !!d.contratto_paga_cena;
            document.getElementById('inclAlloggio').checked = !!d.contratto_paga_alloggio;
            document.getElementById('indFunzione').checked = !!d.ind_funzione_conviventi;
            document.getElementById('indBambini6').checked = !!d.ind_minori_6_anni_ft;
            document.getElementById('indPiuAssistiti').checked = !!d.ind_assistenza_piu_persone_ft;
            document.getElementById('indCertQualita').checked = !!d.ind_certificazione_qualita;
            document.getElementById('toggleScatti').checked = !!d.contratto_applica_scatti;
            document.getElementById('rateo13ma').checked = !!d.contratto_paga_13ma;
            document.getElementById('rateoFerie').checked = !!d.contratto_paga_ferie;
            document.getElementById('rateoFestivi').checked = !!d.contratto_paga_festivi;
            document.getElementById('rateoTfr').checked = d.contratto_modalita_tfr === 'INCLUSO' || d.contratto_modalita_tfr === true;
            window._lastStdPk = pk;
            // Ricalcola con i toggle aggiornati
            selezionaContratto();
            return;
        }
        var r = d.convivenza_rates || {};
        var somma = 0, parti = [];
        if (document.getElementById('inclPranzo').checked) { somma += r.pranzo || 0; parti.push('Pranzo \u20AC' + (r.pranzo || 0).toFixed(2)); }
        if (document.getElementById('inclCena').checked) { somma += r.cena || 0; parti.push('Cena \u20AC' + (r.cena || 0).toFixed(2)); }
        if (document.getElementById('inclAlloggio').checked) { somma += r.alloggio || 0; parti.push('Alloggio \u20AC' + (r.alloggio || 0).toFixed(2)); }
        var gg = parseInt(document.getElementById('giorniConv').value) || 26;
        if (parti.length > 0) {
            document.getElementById('convRiepilogo').textContent = parti.join(' + ') + ' = \u20AC' + somma.toFixed(2) + '/gg \u00d7 ' + gg + 'gg = \u20AC' + (somma * gg).toFixed(2);
        } else {
            document.getElementById('convRiepilogo').textContent = '\u20AC0,00 (nessun item selezionato)';
        }
    })
    .catch(function(e) {
        document.getElementById('bustaLoading').style.display = 'none';
        document.getElementById('bustaContent').innerHTML = '<div class="p-4 text-center" style="color:#f87171;background:rgba(248,113,113,0.08);border:1px solid rgba(248,113,113,0.2);border-radius:14px;"><i class="bi bi-exclamation-triangle me-2"></i>Errore: ' + e.message + '</div>';
    });
};

window.resetToggles = function() {
    var d = window._lastStdData;
    if (!d) return;
    document.getElementById('inclPranzo').checked = !!d.contratto_paga_pranzo;
    document.getElementById('inclCena').checked = !!d.contratto_paga_cena;
    document.getElementById('inclAlloggio').checked = !!d.contratto_paga_alloggio;
    document.getElementById('indFunzione').checked = !!d.ind_funzione_conviventi;
    document.getElementById('indBambini6').checked = !!d.ind_minori_6_anni_ft;
    document.getElementById('indPiuAssistiti').checked = !!d.ind_assistenza_piu_persone_ft;
    document.getElementById('indCertQualita').checked = !!d.ind_certificazione_qualita;
    document.getElementById('toggleScatti').checked = !!d.contratto_applica_scatti;
    document.getElementById('rateo13ma').checked = !!d.contratto_paga_13ma;
    document.getElementById('rateoFerie').checked = !!d.contratto_paga_ferie;
    document.getElementById('rateoFestivi').checked = !!d.contratto_paga_festivi;
    document.getElementById('rateoTfr').checked = d.contratto_modalita_tfr === 'INCLUSO' || d.contratto_modalita_tfr === true;
    selezionaContratto();
};

window.navContratto = function(dir) {
    var newIdx = currIdx + dir;
    if (newIdx < 0 || newIdx >= contrattiList.length) return;
    var sel = document.getElementById('fContratto');
    sel.value = contrattiList[newIdx];
    selezionaContratto();
};

function renderBustaNonConvivente(d) {
    var sogliaLabel = d.sopra_soglia ? 'PI\u00d9 DI ' + Math.floor(Number(d.soglia_ore)) + ' ORE SETTIMANALI' : 'MENO DI ' + Math.floor(Number(d.soglia_ore)) + ' ORE SETTIMANALI';
    var sogliaBadgeBg = d.sopra_soglia ? 'rgba(52,211,153,0.15)' : 'rgba(248,113,113,0.15)';
    var sogliaBadgeColor = d.sopra_soglia ? '#34d399' : '#f87171';
    var sabatiStr = '';
    for (var si = 0; si < d.num_sabati; si++) sabatiStr += '\u2713';

    var tipoLabel = 'Non Convivente';
    if (d.tipo_calcolo === 'SOSTITUZIONE') tipoLabel = 'Sostituzione (Art. 14 c.9)';

    var html = '<div style="background:#17181C;border:1px solid #27282D;border-radius:14px;overflow:hidden;">';

    // Header
    html += '<div style="padding:20px 24px;border-bottom:1px solid #27282D;">';
    html += '<div style="font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:#8A8F98;margin-bottom:4px;"><i class="bi bi-person me-1"></i>Busta Non Convivente \u2014 ' + d.mese_nome + ' ' + d.anno + ' <span style="display:inline-block;margin-left:6px;padding:1px 8px;border-radius:4px;font-size:9px;font-weight:700;background:rgba(168,85,247,0.15);color:#a855f7;">' + tipoLabel + '</span></div>';
    html += '<div class="row g-2 mt-2">';
    html += '<div class="col-md-6"><span style="font-size:10px;color:#8A8F98;display:block;">Datore</span><span style="font-size:13px;font-weight:600;color:#EDEDED;">' + esc(d.datore) + '</span><span style="font-size:11px;color:#8A8F98;display:block;">' + esc(d.datore_indirizzo) + (d.datore_comune ? ' - ' + esc(d.datore_comune) : '') + '</span></div>';
    html += '<div class="col-md-6"><span style="font-size:10px;color:#8A8F98;display:block;">Lavoratore</span><span style="font-size:13px;font-weight:600;color:#EDEDED;">' + esc(d.lavoratore) + '</span><span style="font-size:11px;color:#8A8F98;display:block;">' + esc(d.lavoratore_indirizzo) + (d.lavoratore_comune ? ' - ' + esc(d.lavoratore_comune) : '') + '</span></div>';
    html += '<div class="col-md-3"><span style="font-size:10px;color:#8A8F98;display:block;">Data inizio</span><span style="font-size:13px;font-weight:600;color:#EDEDED;">' + esc(d.data_assunzione) + '</span></div>';
    html += '<div class="col-md-3"><span style="font-size:10px;color:#8A8F98;display:block;">Tipo contratto</span><span style="font-size:13px;font-weight:600;color:#EDEDED;">' + esc(d.tipo_contratto) + '</span></div>';
    var _cH = Math.floor(d.ore_mensili), _cM = Math.floor((d.ore_mensili - _cH) * 60), _cS = Math.floor(((d.ore_mensili - _cH) * 60 - _cM) * 60);
    var _oreCrono = _cH + 'h ' + String(_cM).padStart(2,'0') + 'm ' + String(_cS).padStart(2,'0') + 's';
    var _sA = Math.ceil(d.ore_settimanali);
    html += '<div class="col-md-4"><span style="font-size:10px;color:#8A8F98;display:block;margin-bottom:2px;">Ore</span><div style="display:flex;flex-direction:column;gap:2px;"><div><span style="font-size:13px;font-weight:600;color:#06b6d4;">' + d.ore_inps + ' h</span><span style="font-size:9px;color:#8A8F98;margin-left:3px;">MENSILI ARROTONDATE</span><span style="font-size:9px;color:#8A8F98;margin-left:3px;">(INPS: ' + d.ore_inps + ' h)</span></div><div><span style="font-size:12px;font-weight:500;color:#8A8F98;">' + Number(d.ore_mensili).toFixed(2) + ' h</span><span style="font-size:9px;color:#8A8F98;margin-left:3px;">MENSILI DECIMALI</span></div><div><span style="font-size:12px;font-weight:600;color:#06b6d4;">' + _oreCrono + '</span><span style="font-size:9px;color:#8A8F98;margin-left:3px;">MENSILI CRONOMETRO</span></div><div style="border-top:1px solid #27282D;margin:2px 0;"></div><div><span style="font-size:9px;color:#8A8F98;">Ore settimanali</span> <span style="font-size:13px;font-weight:600;color:#10b981;">' + _sA + ' h</span> <span style="padding:1px 6px;border-radius:4px;font-size:9px;font-weight:700;background:' + sogliaBadgeBg + ';color:' + sogliaBadgeColor + ';">' + sogliaLabel + '</span></div></div></div>';
    html += '<div class="col-md-3"><span style="font-size:10px;color:#8A8F98;display:block;">Settimane mensili</span><span style="font-size:13px;font-weight:600;color:#EDEDED;">' + d.settimane_mensili + ' (' + sabatiStr + ')</span></div>';
    html += '<div class="col-md-3"><span style="font-size:10px;color:#8A8F98;display:block;">Livello</span><span style="font-size:13px;font-weight:600;color:' + esc(d.livello_colore) + ';">' + esc(d.livello_codice) + '</span><span style="font-size:11px;color:#8A8F98;display:block;">' + esc(d.descrizione_corta) + '</span></div>';
    html += '<div class="col-md-3"><span style="font-size:10px;color:#8A8F98;display:block;">Codice Rapporto</span><span style="font-size:12px;font-weight:600;color:#EDEDED;">' + esc(d.codice_rapporto_inps) + '</span></div>';
    html += '<div class="col-md-3"><span style="font-size:10px;color:#8A8F98;display:block;">Paga effettiva INPS</span><span style="font-size:12px;font-weight:600;color:#EDEDED;">\u20AC' + d.paga_effettiva_inps_oraria.toFixed(4) + '/h <span style="font-size:11px;color:#8A8F98;font-weight:400;">(\u20AC' + d.paga_effettiva_inps_mensile.toFixed(2) + '/mese)</span></span></div>';
    html += '<div class="col-md-3"><span style="font-size:10px;color:#8A8F98;display:block;">Paga applicata</span><span style="font-size:12px;font-weight:600;color:#EDEDED;">\u20AC' + d.paga_applicata_oraria.toFixed(4) + '/h <span style="font-size:11px;color:#8A8F98;font-weight:400;">(\u20AC' + d.paga_applicata_mensile.toFixed(2) + '/mese)</span></span></div>';

    // Progetti collegati
    if (d.progetti && d.progetti.length > 0) {
        html += '<div class="col-12 mt-1"><span style="font-size:10px;color:#8A8F98;display:block;margin-bottom:4px;">Progetti collegati</span>';
        for (var pi = 0; pi < d.progetti.length; pi++) {
            var pr = d.progetti[pi];
            html += '<span style="display:inline-flex;align-items:center;gap:4px;padding:2px 10px;border-radius:6px;font-size:11px;font-weight:600;margin-right:6px;margin-bottom:4px;border:1px solid ' + esc(pr.colore) + ';background:rgba(' + hexToRgb(pr.colore) + ',0.1);color:' + esc(pr.colore) + ';">' + esc(pr.nome) + '</span>';
        }
        html += '</div>';
    }

    html += '</div></div>';

    // Corpo
    html += '<div style="padding:20px 24px;">';
    html += '<div class="row g-4">';

    // Colonna sinistra: Retribuzione Lorda
    html += '<div class="col-md-6">';
    html += '<div style="font-size:10px;text-transform:uppercase;letter-spacing:0.06em;color:#34d399;font-weight:700;margin-bottom:8px;"><i class="bi bi-currency-euro me-1"></i>Retribuzione Lorda</div>';

    // Paga base
    html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
    html += '<span style="font-size:12px;color:#EDEDED;">Paga base <span style="color:#8A8F98;font-size:11px;">(\u20AC' + d.paga_base.orario.toFixed(4) + ' \u00d7 ' + d.ore_mensili + 'h)</span></span>';
    html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + d.paga_base.totale.toFixed(2) + '</span></div>';

    // Indennità
    for (var i = 0; i < d.indennita.length; i++) {
        var ind = d.indennita[i];
        html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
        html += '<span style="font-size:12px;color:#EDEDED;">' + esc(ind.label) + ' <span style="color:#8A8F98;font-size:11px;">(\u20AC' + ind.orario.toFixed(4) + ' \u00d7 ' + d.ore_mensili + 'h)</span></span>';
        html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + ind.totale.toFixed(2) + '</span></div>';
    }

    // Scatti
    html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
    html += '<span style="font-size:12px;color:#EDEDED;">Scatti anzianit\u00e0 <span style="color:#8A8F98;font-size:11px;">(' + esc(d.scatti_anzianita.dettaglio) + ')</span></span>';
    html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + d.scatti_anzianita.valore.toFixed(2) + '</span></div>';

    // Ratei pagati
    for (var i = 0; i < d.ratei_pagati.length; i++) {
        var rp = d.ratei_pagati[i];
        var calcNote = rp.incluso ? 'Incluso nel lordo mensile' : (rp.totale > 0 ? 'Da corrispondere a fine rapporto' : '');
        var calcLabel = calcNote ? '<br><span style="font-size:10px;color:#8A8F98;font-style:italic;">' + calcNote + '</span>' : '';
        html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
        html += '<span style="font-size:12px;color:#EDEDED;">' + esc(rp.label) + (rp.incluso ? ' (*)' : '') + ' <span style="color:#8A8F98;font-size:11px;">(\u20AC' + rp.orario.toFixed(4) + ' \u00d7 ' + d.ore_mensili + 'h = \u20AC' + (rp.orario * d.ore_mensili).toFixed(2) + ')</span>' + calcLabel + '</span>';
        html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + rp.totale.toFixed(2) + '</span></div>';
    }

    // Totale indennità e ratei inclusi
    var totalIndennitaRatei = 0;
    for (var iri = 0; iri < d.indennita.length; iri++) totalIndennitaRatei += d.indennita[iri].totale;
    for (var irr = 0; irr < d.ratei_pagati.length; irr++) { if (d.ratei_pagati[irr].incluso) totalIndennitaRatei += d.ratei_pagati[irr].orario * d.ore_mensili; }
    html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
    html += '<span style="font-size:11px;color:#8A8F98;font-style:italic;">Indennit\u00e0 e Ratei pagati</span>';
    html += '<span style="font-size:12px;font-weight:600;color:#EDEDED;">\u20AC ' + totalIndennitaRatei.toFixed(2) + '</span></div>';

    // Totale lordo
    html += '<div class="d-flex justify-content-between align-items-center py-2 mt-2" style="border-top:2px solid rgba(52,211,153,0.3);">';
    html += '<span style="font-size:13px;font-weight:700;color:#34d399;">TOTALE LORDO</span>';
    html += '<span style="font-size:15px;font-weight:800;color:#34d399;">\u20AC ' + d.totale_lordo.toFixed(2) + '</span></div>';

    html += '</div>'; // fine colonna sinistra

    // Colonna destra: Contributi + Trattenute
    html += '<div class="col-md-6">';

    html += '<div style="font-size:10px;text-transform:uppercase;letter-spacing:0.06em;color:#f59e0b;font-weight:700;margin-bottom:8px;"><i class="bi bi-shield me-1"></i>Contributi</div>';

    html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
    html += '<span style="font-size:12px;color:#EDEDED;">INPS <span style="color:#8A8F98;font-size:11px;">(\u20AC' + d.contributi.inps.orario.toFixed(4) + ' \u00d7 ' + d.ore_inps + 'h \u2014 ' + d.contributi.inps.fascia + ' soglia)</span></span>';
    html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + d.contributi.inps.totale.toFixed(2) + '</span></div>';

    html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
    html += '<span style="font-size:12px;color:#EDEDED;">' + esc(d.contributi.cassa.nome || 'Cassa/Ente') + ' <span style="color:#8A8F98;font-size:11px;">(\u20AC' + d.contributi.cassa.orario.toFixed(4) + ' \u00d7 ' + d.ore_inps + 'h)</span></span>';
    html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + d.contributi.cassa.totale.toFixed(2) + '</span></div>';

    html += '<div class="d-flex justify-content-between align-items-center py-2" style="border-top:2px solid rgba(245,158,11,0.3);">';
    html += '<span style="font-size:13px;font-weight:700;color:#f59e0b;">TOTALE CONTRIBUTI</span>';
    html += '<span style="font-size:15px;font-weight:800;color:#f59e0b;">\u20AC ' + d.contributi.totale.toFixed(2) + '</span></div>';

    html += '<div class="d-flex justify-content-between align-items-center py-1" style="margin-top:4px;">';
    html += '<span style="font-size:11px;color:#8A8F98;">Stima contributi trimestrali</span>';
    html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + d.contributi.trimestrale_stima.toFixed(2) + '</span></div>';

    // Trattenute
    html += '<div style="margin-top:24px;font-size:10px;text-transform:uppercase;letter-spacing:0.06em;color:#f87171;font-weight:700;margin-bottom:8px;"><i class="bi bi-dash-circle me-1"></i>Trattenute</div>';

    // Convivenza / Vitto e alloggio
    var convLabel = (d.tipo_calcolo === 'SOSTITUZIONE') ? 'Vitto e alloggio forfettario' : 'Convivenza';
    var convDett = (d.trattenute.convivenza.dettaglio && d.trattenute.convivenza.dettaglio.length > 0) ? d.trattenute.convivenza.dettaglio.join(', ') : '';
    html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
    html += '<span style="font-size:12px;color:#EDEDED;">' + convLabel + ' <span style="color:#8A8F98;font-size:11px;">(' + esc(convDett) + ')</span></span>';
    html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + d.trattenute.convivenza.totale.toFixed(2) + '</span></div>';

    var accNomi = [];
    for (var ri = 0; ri < d.ratei_pagati.length; ri++) { if (!d.ratei_pagati[ri].incluso && d.ratei_pagati[ri].totale > 0) accNomi.push(d.ratei_pagati[ri].label); }
    var accNota = accNomi.length > 0 ? '(' + accNomi.join(', ') + ' non pagati)' : '';
    html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
    html += '<span style="font-size:12px;color:#EDEDED;">Ratei accantonati <span style="font-size:11px;color:#8A8F98;">' + esc(accNota) + '</span></span>';
    html += '<span style="font-size:13px;font-weight:600;color:#EDEDED;">\u20AC ' + d.trattenute.ratei_accantonati.toFixed(2) + '</span></div>';
    var totInclusi = 0, nomiInclusi = [];
    for (var ri = 0; ri < d.ratei_pagati.length; ri++) {
        if (d.ratei_pagati[ri].incluso) { totInclusi += d.ratei_pagati[ri].orario * d.ore_mensili; nomiInclusi.push(d.ratei_pagati[ri].label); }
    }
    if (totInclusi > 0) {
        html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-bottom:1px solid rgba(255,255,255,0.04);">';
        html += '<span style="font-size:12px;color:#8A8F98;font-style:italic;">di cui ratei gi\u00e0 inclusi nel lordo <span style="font-size:11px;">(' + nomiInclusi.join(', ') + ')</span></span>';
        html += '<span style="font-size:12px;font-weight:600;color:#8A8F98;">\u20AC ' + totInclusi.toFixed(2) + '</span></div>';
    }

    if (d.trattenute.totale > 0) {
        html += '<div class="d-flex justify-content-between align-items-center py-2" style="border-top:2px solid rgba(248,113,113,0.3);">';
        html += '<span style="font-size:13px;font-weight:700;color:#f87171;">TOTALE TRATTENUTE</span>';
        html += '<span style="font-size:15px;font-weight:800;color:#f87171;">\u20AC ' + d.trattenute.totale.toFixed(2) + '</span></div>';
    }

    // Riepilogo finale
    html += '<div style="margin-top:20px;padding:16px 0;">';

    html += '<div class="d-flex justify-content-between align-items-center py-1">';
    html += '<span style="font-size:13px;color:#EDEDED;">Budget mensile</span>';
    html += '<span style="font-size:14px;font-weight:600;color:#EDEDED;">\u20AC ' + d.budget_mensile.toFixed(2) + '</span></div>';

    var coperturaOk = Math.abs(d.verifica_copertura) < 0.01;
    var coperturaColor = coperturaOk ? '#34d399' : (d.verifica_copertura > 0 ? '#f59e0b' : '#f87171');
    var coperturaIcon = coperturaOk ? '\u2713' : (d.verifica_copertura > 0 ? '\u2191' : '\u2193');
    html += '<div class="d-flex justify-content-between align-items-center py-1"><span style="font-size:11px;color:#8A8F98;font-style:italic;">Copertura budget</span><span style="font-size:13px;font-weight:700;color:' + coperturaColor + ';">' + coperturaIcon + ' \u20AC ' + Math.abs(d.verifica_copertura).toFixed(2) + '</span></div>';

    if (d.modalita_tfr && d.modalita_tfr !== 'INCLUSO') {
        html += '<div class="d-flex justify-content-between align-items-center py-1" style="border-top:1px solid rgba(245,158,11,0.3);margin-top:2px;">';
        html += '<span style="font-size:11px;color:#f59e0b;font-weight:600;">TFR accumulato</span>';
        html += '<span style="font-size:13px;font-weight:700;color:#f59e0b;">\u20AC ' + Number(d.tfr_accantonato_cumulativo || 0).toFixed(2) + '</span></div>';
    }
    html += '<div class="d-flex justify-content-between align-items-center py-2" style="border-top:1.5px solid #2c5282;margin-top:4px;padding-top:8px;">';
    html += '<span style="font-size:16px;font-weight:800;color:#2c5282;">NETTO IN BUSTA</span>';
    html += '<span style="font-size:20px;font-weight:800;color:#2c5282;">\u20AC ' + d.netto.toFixed(2) + '</span></div>';

    html += '</div></div></div></div>'; // fine colonne

    // Footer
    html += '<div style="padding:16px 24px;border-top:1px solid #27282D;">';

    if (d.note_datore) {
        html += '<div style="margin-bottom:10px;"><span style="font-size:10px;text-transform:uppercase;letter-spacing:0.04em;color:#8A8F98;font-weight:700;display:block;">NOTE DATORE</span>';
        html += '<div style="height:4px;"></div>';
        html += '<span style="font-size:12px;color:#8A8F98;">' + esc(d.note_datore) + '</span></div>';
        html += '<div style="margin-top:10px;padding-top:0;border-top:1px solid #27282D;"></div>';
    }

    html += '<div style="margin-top:14px;font-size:11px;color:#8A8F98;line-height:1.6;">';
    html += 'Firma del collaboratore familiare <span style="color:#EDEDED;font-weight:600;">' + esc(d.lavoratore) + '</span> per ricevuta e conferma delle ore lavorate e retribuite e quietanza dell\'importo indicato.';
    html += '<div style="margin-top:28px;font-size:11px;color:#8A8F98;line-height:1.6;">';
    html += 'Il collaboratore familiare <span style="color:#EDEDED;font-weight:600;">' + esc(d.lavoratore) + '</span> <span style="text-decoration:none;border-bottom:1px solid #8A8F98;display:inline-block;width:360px;">&nbsp;</span>';
    html += '</div></div>';

    html += '<div style="margin-top:8px;margin-bottom:4px;border-top:1px solid #27282D;"></div>';

    var studioParts = [];
    if (d.dati_studio) studioParts.push(esc(d.dati_studio));
    if (d.telefono_studio) studioParts.push('Tel: ' + esc(d.telefono_studio));
    if (d.email_studio) studioParts.push('Mail: ' + esc(d.email_studio));
    if (studioParts.length > 0) {
        html += '<div style="margin-top:14px;padding-top:10px;border-top:1px solid #27282D;font-size:10px;color:#8A8F98;line-height:1.5;">';
        html += '<span style="font-size:9px;text-transform:uppercase;letter-spacing:0.04em;color:#5C5F66;font-weight:700;display:block;">DATI STUDIO</span>';
        html += '<div style="height:4px;"></div>';
        if (d.logo_buste_paga_url) {
            html += '<img src="' + esc(d.logo_buste_paga_url) + '" style="max-height:50px;max-width:180px;display:block;margin-bottom:4px;" alt="Logo studio">';
        }
        html += '<span style="font-size:10px;color:#8A8F98;">' + studioParts.join(' | ') + '</span>';
        html += '</div>';
    }
    if (d.alert_contributi_studio) {
        html += '<div style="margin-top:6px;padding-top:6px;border-top:1px solid #27282D;font-size:10px;color:#8A8F98;line-height:1.5;">';
        html += '<span style="font-size:9px;text-transform:uppercase;letter-spacing:0.04em;color:#5C5F66;font-weight:700;display:block;">SCADENZE</span>';
        html += '<div style="height:4px;"></div>';
        html += '<span style="font-size:10px;color:#8A8F98;">' + d.alert_contributi_studio + '</span>';
        html += '</div>';
    }
    if (d.note_avvertenze) {
        html += '<div style="margin-top:6px;padding-top:6px;border-top:1px solid #27282D;font-size:10px;color:#8A8F98;line-height:1.5;">';
        html += '<span style="font-size:9px;text-transform:uppercase;letter-spacing:0.04em;color:#5C5F66;font-weight:700;display:block;">NOTE AGGIUNTIVE / AVVERTENZE</span>';
        html += '<div style="height:4px;"></div>';
        html += '<span style="font-size:10px;color:#8A8F98;">' + d.note_avvertenze + '</span>';
        html += '</div>';
    }

    html += '<div style="margin-top:18px;padding-top:10px;border-top:1.5px solid #27282D;font-size:8px;color:#5C5F66;text-align:center;">';
    html += 'Tutti i diritti riservati: \u00e8 vietata la riproduzione, anche parziale, dei contenuti. | Stampata il ' + new Date().toLocaleDateString('it-IT');
    html += '</div>';

    html += '</div></div>';

    // ── Dettaglio Progetti (se presenti) ──
    if (d.progetti_data && d.progetti_data.righe && d.progetti_data.righe.length > 0) {
        html += '<div style="margin-top:24px;background:#17181C;border:1px solid #27282D;border-radius:14px;overflow:hidden;">';
        html += '<div style="padding:16px 24px;">';
        html += '<div style="display:flex;justify-content:space-between;align-items:center;border-bottom:1.5px solid #2c5282;padding-bottom:6px;margin-bottom:12px;">';
        html += '<span style="font-size:15px;font-weight:800;color:#2c5282;">Dettaglio Progetti</span>';
        html += '<span style="font-size:11px;color:#8A8F98;">' + esc(d.mese_nome) + ' ' + d.anno + '</span>';
        html += '</div>';

        // Tabella
        html += '<div style="display:table;width:100%;">';
        // Header
        html += '<div style="display:table-row;background:rgba(255,255,255,0.04);font-size:9px;text-transform:uppercase;letter-spacing:0.04em;color:#8A8F98;font-weight:700;">';
        html += '<div style="display:table-cell;padding:6px 4px;">Progetto</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">Lordo Progetto</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">Unit\u00e0 (Paga/h)</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:center;">Ore</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">Contrib. Totali</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">Ratei ed Indennit\u00e0</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">Netto</div>';
        html += '</div>';

        var pd = d.progetti_data;
        for (var ri = 0; ri < pd.righe.length; ri++) {
            var rr = pd.righe[ri];
            html += '<div style="display:table-row;border-bottom:1px solid rgba(255,255,255,0.04);">';
            html += '<div style="display:table-cell;padding:5px 4px;font-size:11px;color:#8A8F98;">' + esc(rr.nome) + '</div>';
            html += '<div style="display:table-cell;padding:5px 4px;font-size:11px;color:#EDEDED;text-align:right;">\u20AC ' + rr.lordo_progetto.toFixed(2) + '</div>';
            html += '<div style="display:table-cell;padding:5px 4px;font-size:11px;color:#EDEDED;text-align:right;">\u20AC ' + rr.paga_oraria.toFixed(4) + '</div>';
            html += '<div style="display:table-cell;padding:5px 4px;font-size:11px;color:#EDEDED;text-align:center;">' + rr.ore.toFixed(2) + '</div>';
            html += '<div style="display:table-cell;padding:5px 4px;font-size:11px;color:#EDEDED;text-align:right;">\u20AC ' + rr.contrib.toFixed(2) + '</div>';
            html += '<div style="display:table-cell;padding:5px 4px;font-size:11px;color:#EDEDED;text-align:right;">\u20AC ' + rr.ratei_ind.toFixed(2) + '</div>';
            html += '<div style="display:table-cell;padding:5px 4px;font-size:11px;color:#EDEDED;text-align:right;font-weight:700;">\u20AC ' + rr.netto.toFixed(2) + '</div>';
            html += '</div>';
        }

        // Totali
        var t = pd.totali;
        html += '<div style="display:table-row;border-top:2px solid #2c5282;font-size:12px;font-weight:700;color:#2c5282;">';
        html += '<div style="display:table-cell;padding:6px 4px;">TOTALE</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">\u20AC ' + t.lordo_progetto.toFixed(2) + '</div>';
        html += '<div style="display:table-cell;padding:6px 4px;"></div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:center;">' + t.ore.toFixed(2) + '</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">\u20AC ' + t.contrib.toFixed(2) + '</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">\u20AC ' + t.ratei_ind.toFixed(2) + '</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;"></div>';
        html += '</div>';

        // Netto
        html += '<div style="display:table-row;font-size:14px;font-weight:800;color:#2c5282;">';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;" colspan="6">NETTO</div>';
        html += '<div style="display:table-cell;padding:6px 4px;text-align:right;">\u20AC ' + t.netto.toFixed(2) + '</div>';
        html += '</div>';

        // Rigo riepilogativo compatto
        html += '<div style="margin-top:10px;padding-top:8px;border-top:1px solid #27282D;font-size:11px;color:#8A8F98;">';
        var riep_parts = [];
        if (d.indennita && d.indennita.length > 0) {
            var indItems = [];
            for (var ii = 0; ii < d.indennita.length; ii++) {
                indItems.push(d.indennita[ii].label + ' \u20AC' + d.indennita[ii].totale.toFixed(2));
            }
            riep_parts.push('Ind.: ' + indItems.join(' + ') + ' = \u20AC' + d.totale_indennita.toFixed(2) + ' (' + d.indennita.length + ')');
        }
        if (d.ratei_pagati && d.ratei_pagati.length > 0) {
            var rateiInclTot = 0, rateiAccTot = 0, countIncl = 0, countAcc = 0;
            var inclLabels = [], accLabels = [];
            for (var ir = 0; ir < d.ratei_pagati.length; ir++) {
                var r_ = d.ratei_pagati[ir];
                if (r_.incluso) { countIncl++; rateiInclTot += (r_.valore_effettivo || 0); inclLabels.push(r_.label); }
                else { countAcc++; rateiAccTot += (r_.valore_effettivo || r_.totale || 0); accLabels.push(r_.label); }
            }
            var rateiPart = 'Ratei:';
            if (countIncl > 0) { rateiPart += ' +\u20AC' + rateiInclTot.toFixed(2) + ' (' + inclLabels.join(',') + ' \u2014 ' + countIncl + ' INCLUSI)'; }
            if (countAcc > 0) { rateiPart += ' +\u20AC' + rateiAccTot.toFixed(2) + ' (' + accLabels.join(',') + ' \u2014 ' + countAcc + ' NON INCLUSO' + (countAcc > 1 ? ' E ACCANTONATI' : ' E ACCANTONATO') + ')'; }
            riep_parts.push(rateiPart);
        }
        if (d.trattenute && d.trattenute.convivenza) {
            if (d.trattenute.convivenza.totale > 0) {
                riep_parts.push('Conv.: INCLUSA \u20AC' + d.trattenute.convivenza.totale.toFixed(2));
            } else {
                riep_parts.push('Conv.: NON INCLUSA');
            }
        }
        if (d.scatti_anzianita) {
            if (d.scatti_anzianita.dettaglio && d.scatti_anzianita.dettaglio !== 'NON INCLUSI') {
                riep_parts.push('Scatti: ' + d.scatti_anzianita.dettaglio + ' = \u20AC' + d.scatti_anzianita.valore.toFixed(2));
            } else {
                riep_parts.push('Scatti: NON INCLUSI');
            }
        }
        html += riep_parts.join(' &nbsp;|&nbsp; ');
        html += '</div>';

        html += '</div></div>';
    }

    document.getElementById('bustaContent').innerHTML = html;
}

function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function hexToRgb(hex) {
    var r = parseInt(hex.slice(1, 3), 16);
    var g = parseInt(hex.slice(3, 5), 16);
    var b = parseInt(hex.slice(5, 7), 16);
    return r + ',' + g + ',' + b;
}

window.downloadPdf = function() {
    var pk = document.getElementById('btnPdf').dataset.pk;
    if (!pk) return;
    var mese = document.getElementById('fMese').value;
    var anno = document.getElementById('fAnno').value;
    var sost = document.getElementById('sostituzioneToggle').checked ? '1' : '0';
    var inclPranzo = document.getElementById('inclPranzo').checked ? '1' : '0';
    var inclCena = document.getElementById('inclCena').checked ? '1' : '0';
    var inclAlloggio = document.getElementById('inclAlloggio').checked ? '1' : '0';
    var giorniConv = document.getElementById('giorniConv').value;
    var indFn = document.getElementById('indFunzione').checked ? '1' : '0';
    var indB6 = document.getElementById('indBambini6').checked ? '1' : '0';
    var indPA = document.getElementById('indPiuAssistiti').checked ? '1' : '0';
    var indCQ = document.getElementById('indCertQualita').checked ? '1' : '0';
    var scatti = document.getElementById('toggleScatti').checked ? '1' : '0';
    var r13ma = document.getElementById('rateo13ma').checked ? '1' : '0';
    var rferie = document.getElementById('rateoFerie').checked ? '1' : '0';
    var rfest = document.getElementById('rateoFestivi').checked ? '1' : '0';
    var rtfr = document.getElementById('rateoTfr').checked ? '1' : '0';
    apriNelPannello('/ajax/busta-non-convivente-pdf/' + pk + '/?mese=' + mese + '&anno=' + anno
        + '&sostituzione=' + sost + '&incl_pranzo=' + inclPranzo + '&incl_cena=' + inclCena
        + '&incl_alloggio=' + inclAlloggio + '&giorni_conv=' + giorniConv
        + '&ind_funzione=' + indFn + '&ind_bambini_6=' + indB6
        + '&ind_piu_assistiti=' + indPA + '&ind_cert_qualita=' + indCQ
        + '&scatti=' + scatti + '&rateo_tfr=' + rtfr + '&rateo_13ma=' + r13ma
        + '&rateo_ferie=' + rferie + '&rateo_festivi=' + rfest);
};

function getCSRFToken() {
    var name = 'csrftoken';
    var value = '; ' + document.cookie;
    var parts = value.split('; ' + name + '=');
    if (parts.length === 2) return parts.pop().split(';').shift();
    return '';
}
window.salvaBusta = function() {
    var pk = document.getElementById('btnSalvaBusta').dataset.pk;
    if (!pk) return;
    var warn = document.getElementById('bustaEsistenteWarning');
    if (warn && warn.style.display !== 'none' && warn.style.display !== '') {
        if (!confirm('Busta paga già salvata per questo periodo. Sovrascrivere?')) return;
    }
    var btn = document.getElementById('btnSalvaBusta');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> SALVATAGGIO...';
    var tipoCalc = document.getElementById('sostituzioneToggle').checked ? 'SOSTITUZIONE' : 'NON_CONVIVENTE';
    var formData = new FormData();
    formData.append('contratto_pk', pk);
    formData.append('mese', document.getElementById('fMese').value);
    formData.append('anno', document.getElementById('fAnno').value);
    formData.append('tipo_calcolo', tipoCalc);
    formData.append('csrfmiddlewaretoken', getCSRFToken());
    fetch('/ajax/salva-busta/', {
        method: 'POST',
        body: formData,
        credentials: 'same-origin',
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
    }).then(function(r) { return r.json(); }).then(function(d) {
        if (d.ok) {
            btn.innerHTML = '<i class="bi bi-check-lg me-1"></i> SALVATA';
            setTimeout(function() {
                btn.innerHTML = '<i class="bi bi-save me-1"></i> SALVA BUSTA';
                btn.disabled = false;
            }, 2000);
        } else {
            mostraToast(d.errore || 'Errore salvataggio', false);
            btn.innerHTML = '<i class="bi bi-save me-1"></i> SALVA BUSTA';
            btn.disabled = false;
        }
    }).catch(function(e) {
        console.error(e);
        mostraToast('Errore di rete', false);
        btn.innerHTML = '<i class="bi bi-save me-1"></i> SALVA BUSTA';
        btn.disabled = false;
    });
};

window.vaiContratto = function() {
    var pk = document.getElementById('btnContratto').dataset.pk;
    if (pk) loadAjaxForm('/ajax/modifica-contratto/' + pk + '/', 'Modifica Contratto');
};

window.stampaBustaCalcolo = function(btn) {
    var pk = document.getElementById('btnPdf').dataset.pk;
    if (!pk) { mostraToast('Nessuna busta selezionata.', false); return; }
    var d = window._lastStdData;
    if (!d || !d.busta_esistente) {
        mostraToast('Salva prima la busta paga con "SALVA BUSTA".', false);
        return;
    }
    stampaBusta(pk, btn);
};

document.addEventListener('DOMContentLoaded', function() {
    var sel = document.getElementById('fContratto');
    if (sel.value) {
        selezionaContratto();
    }
});
</script>
{% endblock %}