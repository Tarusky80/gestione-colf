def _dati_eliminato(obj):
    """Serializza un oggetto inclusi i campi ManyToMany (esclusi di default)."""
    dati = json.loads(serializers.serialize('json', [obj]))
    for m2m in obj._meta.many_to_many:
        pks = list(getattr(obj, m2m.name).values_list('pk', flat=True))
        if pks:
            dati[0]['fields'][m2m.name] = pks
    return dati

# 1. DASHBOARD PRINCIPALE
@login_required
@never_cache
def dashboard(request):
    opzioni = OpzioniSoftware.objects.first()
    contratti_attivi_qs = ContrattoAttivo.objects.filter(stato='ATTIVO')
    totale_attivi = contratti_attivi_qs.count()

    # Stats - Per Comune
    contratti_per_comune = (contratti_attivi_qs.values('datore__comune')
                           .annotate(count=Count('id'))
                           .order_by('-count')[:5])

    # Stats - Tipologia
    tipi = (contratti_attivi_qs.values('tipo_contratto')
            .annotate(count=Count('id')))

    conviventi = contratti_attivi_qs.filter(is_convivente=True).count()
    non_conviventi = totale_attivi - conviventi

    # Stats - Progetti (tutti i tipi, anche count=0)
    progetti_data = []
    for tipo in TipoProgettoRegionale.objects.all():
        cnt = contratti_attivi_qs.filter(progetto__tipo=tipo).distinct().count()
        progetti_data.append({'nome': tipo.nome, 'count': cnt, 'colore': tipo.colore})

    con_progetto = contratti_attivi_qs.annotate(prog=Count('progetto')).filter(prog__gt=0).count()
    senza_progetto = totale_attivi - con_progetto

    # Stats - Budget
    budget_totale = ProgettoRegionale.objects.aggregate(
        totale=Sum('budget_mensile')
    )['totale'] or 0
    contratti_con_budget = con_progetto
    budget_medio = round(budget_totale / contratti_con_budget, 2) if contratti_con_budget > 0 else 0

    # Ore totali mensili
    ore_totali = contratti_attivi_qs.aggregate(
        totale=Sum('ore_calcolate')
    )['totale'] or 0

    # Budget per tipo progetto (per il grafico a torta)
    budget_per_tipo_qs = (ProgettoRegionale.objects
                          .values('tipo__nome', 'tipo__colore')
                          .annotate(totale=Sum('budget_mensile'))
                          .order_by('-totale'))
    budget_per_tipo = list(budget_per_tipo_qs)
    # Livelli (solo quelli con contratti attivi)
    livelli = (contratti_attivi_qs
               .values('parametri_minimi__livello__codice', 'parametri_minimi__livello__colore')
               .annotate(count=Count('id'))
               .order_by('parametri_minimi__livello__codice'))
    # Contratti in scadenza (data_fine prossimi 30 giorni)
    tra_30gg = date.today() + timedelta(days=30)
    contratti_in_scadenza = (ContrattoAttivo.objects
                             .filter(progetto__data_fine__gte=date.today(),
                                     progetto__data_fine__lte=tra_30gg)
                             .distinct().count())

    # ==========================================
    # ALERT per pannello laterale
    # ==========================================
    oggi = date.today()

    # 1. Scaduti da aggiornare
    scaduti_qs = ContrattoAttivo.objects.filter(
        progetto__data_fine__lt=oggi
    ).distinct()
    scaduti_count = scaduti_qs.count()
    scaduti_items = list(scaduti_qs.select_related('datore', 'lavoratore').prefetch_related('progetto')[:20])

    # 2. Nuovi assunti questo mese
    nuovi_mese = contratti_attivi_qs.filter(
        data_assunzione__year=oggi.year,
        data_assunzione__month=oggi.month
    ).count()

    # 3. Senza budget
    senza_budget_qs = contratti_attivi_qs.annotate(
        prog_count=Count('progetto'),
        budget_sum=Sum('progetto__budget_mensile')
    ).filter(
        Q(prog_count=0) | Q(budget_sum=0) | Q(budget_sum__isnull=True)
    )
    senza_budget_count = senza_budget_qs.count()
    senza_budget_items = list(senza_budget_qs.select_related('datore', 'lavoratore')[:20])

    # 4. Anagrafiche incomplete
    datori_incompleti = DatoreLavoro.objects.filter(
        Q(comune='') | Q(indirizzo='') | Q(email__isnull=True) | Q(telefono__isnull=True)
    ).count()
    lavoratori_incompleti = Lavoratore.objects.filter(
        Q(comune='') | Q(indirizzo='') | Q(email__isnull=True) | Q(telefono__isnull=True)
    ).count()

    # % Anagrafiche complete
    totale_anagrafiche = DatoreLavoro.objects.count() + Lavoratore.objects.count()
    incomplete_anagrafiche = datori_incompleti + lavoratori_incompleti
    anagrafiche_complete_pct = round((totale_anagrafiche - incomplete_anagrafiche) / totale_anagrafiche * 100) if totale_anagrafiche > 0 else 100

    # 5. Prossima scadenza contributi (trimestrale)
    mese = oggi.month
    if mese <= 3:
        trimestre = 1
        scadenza_mese = 4
        scadenza_giorno = 10
        inizio_trimestre = date(oggi.year, 1, 1)
    elif mese <= 6:
        trimestre = 2
        scadenza_mese = 7
        scadenza_giorno = 10
        inizio_trimestre = date(oggi.year, 4, 1)
    elif mese <= 9:
        trimestre = 3
        scadenza_mese = 10
        scadenza_giorno = 10
        inizio_trimestre = date(oggi.year, 7, 1)
    else:
        trimestre = 4
        scadenza_mese = 1
        scadenza_giorno = 10
        inizio_trimestre = date(oggi.year, 10, 1)

    if trimestre == 4:
        prossima_scadenza = date(oggi.year + 1, 1, 10)
    else:
        prossima_scadenza = date(oggi.year, scadenza_mese, scadenza_giorno)

    # Se siamo già oltre la scadenza, calcola la prossima
    if oggi > prossima_scadenza:
        if trimestre == 4:
            trimestre = 1
            prossima_scadenza = date(oggi.year + 1, 4, 10)
        else:
            trimestre += 1
            mesi_map = {1: 4, 2: 7, 3: 10, 4: 1}
            prossima_scadenza = date(
                oggi.year if trimestre != 4 else oggi.year + 1,
                mesi_map[trimestre], 10
            )

    # 6. Trimestre parziale (assunti dopo l'inizio del trimestre)
    trimestre_parziale_qs = contratti_attivi_qs.filter(
        data_assunzione__gt=inizio_trimestre
    )
    trimestre_parziale_count = trimestre_parziale_qs.count()
    trimestre_parziale_items = list(
        trimestre_parziale_qs.select_related('datore', 'lavoratore')[:20]
    )
    trimestre_parziale_mese = inizio_trimestre

    # Totale alert
    totale_alert = (
        scaduti_count +
        contratti_in_scadenza +
        (1 if nuovi_mese > 0 else 0) +
        senza_progetto +
        senza_budget_count +
        (1 if datori_incompleti > 0 or lavoratori_incompleti > 0 else 0) +
        (1 if trimestre_parziale_count > 0 else 0)
    )

    # Andamento mensile (ultimi 12 mesi: assunzioni, cessazioni, confronto)
    from django.db.models.functions import TruncMonth
    ultimi_12 = oggi - timedelta(days=365)
    andamento_assunzioni = (ContrattoLavoro.objects
                          .filter(data_assunzione__gte=ultimi_12)
                          .annotate(mese=TruncMonth('data_assunzione'))
                          .values('mese')
                          .annotate(count=Count('id'))
                          .order_by('mese'))
    # Cessazioni approssimative: data_fine dei progetti
    andamento_cessazioni = (ProgettoRegionale.objects
                          .filter(data_fine__gte=ultimi_12)
                          .annotate(mese=TruncMonth('data_fine'))
                          .values('mese')
                          .annotate(count=Count('id', distinct=True))
                          .order_by('mese'))
    # Unisci le label da entrambi i dataset (tutti i mesi presenti)
    mesi_set = set()
    assunzioni_map = {}
    for entry in andamento_assunzioni:
        m = entry['mese'].strftime('%b %y') if entry['mese'] else ''
        mesi_set.add(m)
        assunzioni_map[m] = entry['count']
    cessazioni_map = {}
    for entry in andamento_cessazioni:
        m = entry['mese'].strftime('%b %y') if entry['mese'] else ''
        mesi_set.add(m)
        cessazioni_map[m] = entry['count']
    mesi_labels = sorted(mesi_set, key=lambda x: x)
    assunzioni_counts = [assunzioni_map.get(m, 0) for m in mesi_labels]
    cessazioni_counts = [cessazioni_map.get(m, 0) for m in mesi_labels]

    context = {
        'opzioni': opzioni,
        'datori_count': DatoreLavoro.objects.count(),
        'lavoratori_count': Lavoratore.objects.count(),
        'beneficiari_count': Beneficiario.objects.count(),
        'totale_attivi': totale_attivi,
        'mesi_labels': mesi_labels,
        'mesi_counts': assunzioni_counts,
        'cessazioni_counts': cessazioni_counts,
        'contratti_per_comune': contratti_per_comune,
        'tipi': tipi,
        'conviventi': conviventi,
        'non_conviventi': non_conviventi,
        'con_progetto': con_progetto,
        'senza_progetto': senza_progetto,
        'progetti_data': progetti_data,
        'budget_totale': budget_totale,
        'budget_medio': budget_medio,
        'budget_per_tipo': budget_per_tipo,
        'livelli': livelli,
        'contratti_in_scadenza': contratti_in_scadenza,
        'contratti': (contratti_attivi_qs
                     .select_related('datore', 'lavoratore', 'parametri_minimi__livello')
                     .prefetch_related('progetto__tipo', 'progetto__beneficiario')
                     .order_by('-data_assunzione')[:10]),
        'mese_corr': oggi.month,
        'anno_corr': oggi.year,
        'mese_prec': oggi.month - 1 if oggi.month > 1 else 12,
        'anno_prec': oggi.year if oggi.month > 1 else oggi.year - 1,
        'mese_succ': oggi.month + 1 if oggi.month < 12 else 1,
        'anno_succ': oggi.year if oggi.month < 12 else oggi.year + 1,
        # Alert pannello
        'scaduti_count': scaduti_count,
        'scaduti_items': scaduti_items,
        'nuovi_mese': nuovi_mese,
        'senza_budget_count': senza_budget_count,
        'senza_budget_items': senza_budget_items,
        'datori_incompleti': datori_incompleti,
        'lavoratori_incompleti': lavoratori_incompleti,
        'prossima_scadenza': prossima_scadenza,
        'trimestre_parziale_count': trimestre_parziale_count,
        'trimestre_parziale_items': trimestre_parziale_items,
        'trimestre_parziale_mese': trimestre_parziale_mese,
        'totale_alert': totale_alert,
        'ore_totali': ore_totali,
        'anagrafiche_complete_pct': anagrafiche_complete_pct,
    }
    return render(request, 'paghe/dashboard.html', context)

# LISTE PRINCIPALI PER SIDEBAR
@login_required
@never_cache
def datori_list(request):
    opzioni = OpzioniSoftware.objects.first()
    datori = DatoreLavoro.objects.all().order_by('nome_cognome')
    comuni = DatoreLavoro.objects.exclude(comune='').exclude(comune__isnull=True)\
        .values_list('comune', flat=True).distinct().order_by('comune')
    context = {
        'opzioni': opzioni,
        'datori': datori,
        'count': datori.count(),
        'comuni': comuni,
    }
    return render(request, 'paghe/datori_list.html', context)

