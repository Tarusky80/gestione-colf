TABELLE_MAP = {
    'progetti-regionali': {'model': ProgettoRegionale, 'form': ProgettoRegionaleForm, 'titolo': 'Progetti Regionali', 'icona': 'diagram-3'},
    'parametri-ccnl': {'model': ParametriCCNL, 'form': ParametriCCNLForm, 'titolo': 'Parametri CCNL', 'icona': 'sliders'},
    'tabelle-casse': {'model': TabellaCasse, 'form': TabellaCasseForm, 'titolo': 'Tabella Casse', 'icona': 'cash-stack'},
    'contributi-inps': {'model': TabellaContributiINPS, 'form': TabellaContributiINPSForm, 'titolo': 'Contributi INPS', 'icona': 'percent'},
    'malattia': {'model': TabellaMalattia, 'form': TabellaMalattiaForm, 'titolo': 'Tabella Malattia', 'icona': 'heart-pulse'},
    'scatti-anzianita': {'model': TabellaScattiAnzianita, 'form': TabellaScattiAnzianitaForm, 'titolo': 'Scatti Anzianità', 'icona': 'arrow-up-circle'},
    'testi-preimpostati': {'model': TestoPreimpostato, 'form': TestoPreimpostatoForm, 'titolo': 'Testo Preimpostato', 'icona': 'file-text'},
    'tipi-progetto': {'model': TipoProgettoRegionale, 'form': TipoProgettoRegionaleForm, 'titolo': 'Tipo Progetto', 'icona': 'tags'},
    'livelli': {'model': Livello, 'form': LivelloForm, 'titolo': 'Livelli', 'icona': 'layers'},
    'modelli-lista': {'model': ModelloLista, 'form': ModelloListaForm, 'titolo': 'Modelli Lista', 'icona': 'file-earmark-spreadsheet'},
}

def _get_tabella_conf(tipo):
    conf = TABELLE_MAP.get(tipo)
    if not conf:
        return None
    return {
        'model': conf['model'],
        'form_class': conf['form'],
        'titolo': conf['titolo'],
        'icona': conf['icona'],
        'tipo_url': tipo,
    }

@login_required
@never_cache
def tabella_list(request, tipo):
    conf = _get_tabella_conf(tipo)
    if not conf:
        return render(request, 'paghe/tabella_generica.html', {'error': 'Tabella non trovata'})
    model = conf['model']
    objects = model.objects.all()

    # Build fields metadata for generic table rendering
    meta_fields = model._meta.get_fields()
    fields = []
    for f in meta_fields:
        if hasattr(f, 'name') and not f.name.startswith('_') and not f.auto_created and f.name != 'id' and f.name != 'pk':
            ftype = f.get_internal_type() if hasattr(f, 'get_internal_type') else ''
            # Skip M2M fields (not suitable for table display)
            if ftype == 'ManyToManyField':
                continue
            fields.append({
                'name': f.name,
                'verbose_name': getattr(f, 'verbose_name', f.name).upper() if hasattr(f, 'verbose_name') else f.name.upper(),
                'type': ftype,
            })

    ctx = {
        'opzioni': OpzioniSoftware.objects.first(),
        'titolo': conf['titolo'],
        'icona': conf['icona'],
        'objects': objects,
        'fields': fields,
        'model_name': model._meta.model_name,
        'verbose_name': model._meta.verbose_name,
        'tipo_url': tipo,
    }
    if tipo == 'parametri-ccnl':
        ctx['keep_fields'] = ['livello', 'descrizione_corta', 'descrizione_lunga', 'anno', 'paga_base']
        ctx['truncate_fields'] = ['descrizione_lunga']
        ctx['years'] = (ParametriCCNL.objects.values('anno')
                        .distinct().order_by('-anno'))
    if tipo == 'testi-preimpostati':
        ctx['truncate_fields'] = ['corpo_testo']
        for obj in objects:
            obj.corpo_testo = _risolvi_globali(obj.corpo_testo or '')
    if tipo == 'progetti-regionali':
        from .models import TipoProgettoRegionale
        ctx['tipi'] = TipoProgettoRegionale.objects.all()
        return render(request, 'paghe/progetti_regionali_list.html', ctx)
    if tipo == 'modelli-lista':
        return render(request, 'paghe/modelli_lista_list.html', ctx)
    return render(request, 'paghe/tabella_generica.html', ctx)

@login_required
def ajax_nuovo_tabella(request, tipo):
    conf = _get_tabella_conf(tipo)
    if not conf:
        return JsonResponse({'success': False, 'message': 'Tabella non trovata'})
    model = conf['model']
    form_class = conf['form_class']
    template = 'frontend/ajax_form_progetto.html' if tipo == 'progetti-regionali' else 'frontend/ajax_form_testo.html' if tipo == 'testi-preimpostati' else 'frontend/ajax_form_tabella_numeri.html' if tipo in ('tabelle-casse','contributi-inps') else 'frontend/ajax_form_parametri_ccnl.html' if tipo == 'parametri-ccnl' else 'frontend/ajax_form_tabella.html'
    opz = OpzioniSoftware.objects.first()
    ctx = {'form': None, 'titolo': conf['titolo'], 'model_name': model._meta.model_name, 'tiny_api_key': opz.tiny_api_key if opz else '', 'tipo': tipo}
    if tipo == 'progetti-regionali':
        ctx['contratti_collegati'] = []
    if request.method == 'POST':
        form = form_class(request.POST)
        ctx['form'] = form
        if form.is_valid():
            form.save()
            return JsonResponse({'success': True})
        html = render_to_string(template, ctx, request=request)
        return JsonResponse({'success': False, 'html': html})
    else:
        ctx['form'] = form_class()
        html = render_to_string(template, ctx, request=request)
        return JsonResponse({'success': True, 'html': html})

@login_required
def ajax_modifica_tabella(request, tipo, pk):
    conf = _get_tabella_conf(tipo)
    if not conf:
        return JsonResponse({'success': False, 'message': 'Tabella non trovata'})
    model = conf['model']
    form_class = conf['form_class']
    obj = get_object_or_404(model, pk=pk)
    template = 'frontend/ajax_form_progetto.html' if tipo == 'progetti-regionali' else 'frontend/ajax_form_testo.html' if tipo == 'testi-preimpostati' else 'frontend/ajax_form_tabella_numeri.html' if tipo in ('tabelle-casse','contributi-inps') else 'frontend/ajax_form_parametri_ccnl.html' if tipo == 'parametri-ccnl' else 'frontend/ajax_form_tabella.html'
    opz = OpzioniSoftware.objects.first()
    ctx = {'form': None, 'titolo': conf['titolo'], 'model_name': model._meta.model_name, 'tiny_api_key': opz.tiny_api_key if opz else '', 'tipo': tipo, 'instance': obj}
    if tipo == 'progetti-regionali':
        ctx['contratti_collegati'] = ContrattoLavoro.objects.filter(progetto=obj) if obj.pk else []
        progetti_qs = ProgettoRegionale.objects.select_related('beneficiario').order_by('beneficiario__nome_cognome')
        progetti_pks = list(progetti_qs.values_list('pk', flat=True))
        progetti_nav_data = [{'pk': p.pk, 'label': f"{p.beneficiario.nome_cognome} - {p.tipo.nome if p.tipo else 'N/D'}"} for p in progetti_qs]
        ctx['progetti_pks'] = progetti_pks
        ctx['progetto_pk_attuale'] = int(pk)
        ctx['progetti_nav_data'] = progetti_nav_data
    if request.method == 'POST':
        form = form_class(request.POST, instance=obj)
        ctx['form'] = form
        if form.is_valid():
            form.save()
            return JsonResponse({'success': True})
        html = render_to_string(template, ctx, request=request)
        return JsonResponse({'success': False, 'html': html})
    else:
        form = form_class(instance=obj)
        ctx['form'] = form
        html = render_to_string(template, ctx, request=request)
        return JsonResponse({'success': True, 'html': html})

@login_required
def ajax_duplica_tabella(request, tipo, pk):
    conf = _get_tabella_conf(tipo)
    if not conf:
        return JsonResponse({'success': False, 'message': 'Tabella non trovata'})
    model = conf['model']
    form_class = conf['form_class']
    obj = get_object_or_404(model, pk=pk)
    template = 'frontend/ajax_form_progetto.html' if tipo == 'progetti-regionali' else 'frontend/ajax_form_testo.html' if tipo == 'testi-preimpostati' else 'frontend/ajax_form_tabella_numeri.html' if tipo in ('tabelle-casse','contributi-inps') else 'frontend/ajax_form_parametri_ccnl.html' if tipo == 'parametri-ccnl' else 'frontend/ajax_form_tabella.html'
    opz = OpzioniSoftware.objects.first()
    ctx = {'form': None, 'titolo': 'Duplica ' + conf['titolo'], 'model_name': model._meta.model_name, 'tiny_api_key': opz.tiny_api_key if opz else ''}
    if tipo == 'progetti-regionali':
        ctx['contratti_collegati'] = []
    if request.method == 'POST':
        form = form_class(request.POST)
        ctx['form'] = form
        if form.is_valid():
            form.save()
            return JsonResponse({'success': True})
        html = render_to_string(template, ctx, request=request)
        return JsonResponse({'success': False, 'html': html})
    initial = {}
    for f in model._meta.get_fields():
        if hasattr(f, 'name') and not f.auto_created and not f.primary_key and f.name != 'id':
            initial[f.name] = getattr(obj, f.name)
    ctx['form'] = form_class(initial=initial)
    html = render_to_string(template, ctx, request=request)
    return JsonResponse({'success': True, 'html': html})

@login_required
@require_http_methods(["POST"])
def ajax_elimina_tabella(request, tipo, pk):
    conf = _get_tabella_conf(tipo)
    if not conf:
        return JsonResponse({'success': False, 'message': 'Tabella non trovata'})
    model = conf['model']
    obj = get_object_or_404(model, pk=pk)
    # Salva nel cestino prima di eliminare
    RecordEliminato.objects.create(
        tipo=tipo,
        original_pk=str(obj.pk),
        dati=_dati_eliminato(obj),
        descrizione=str(obj),
    )
    obj.delete()
    return JsonResponse({'success': True})

