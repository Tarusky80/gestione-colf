@login_required
@never_cache
def contratti_list(request):
    opzioni = OpzioniSoftware.objects.first()
    contratti = (ContrattoAttivo.objects
                 .filter(stato='ATTIVO')
                 .select_related('datore', 'lavoratore', 'parametri_minimi__livello')
                 .prefetch_related('progetto__tipo', 'progetto__beneficiario')
                 .all().order_by('-data_assunzione'))
    livelli = Livello.objects.all()
    tipi_progetto = TipoProgettoRegionale.objects.all()
    # Comuni unici dai beneficiari dei progetti dei contratti attivi
    comuni = Beneficiario.objects.filter(
        progettoregionale__contrattolavoro__stato='ATTIVO'
    ).exclude(comune='').exclude(comune__isnull=True)\
    .values_list('comune', flat=True).distinct().order_by('comune')
    oggi = date.today()
    mese_corr = oggi.month
    anno_corr = oggi.year
    mese_prec = mese_corr - 1 if mese_corr > 1 else 12
    anno_prec = anno_corr if mese_corr > 1 else anno_corr - 1
    mese_succ = mese_corr + 1 if mese_corr < 12 else 1
    anno_succ = anno_corr if mese_corr < 12 else anno_corr + 1
    context = {
        'opzioni': opzioni,
        'contratti': contratti,
        'livelli': livelli,
        'tipi_progetto': tipi_progetto,
        'comuni': comuni,
        'count': contratti.count(),
        'mese_corr': mese_corr,
        'anno_corr': anno_corr,
        'mese_prec': mese_prec,
        'anno_prec': anno_prec,
        'mese_succ': mese_succ,
        'anno_succ': anno_succ,
    }
    return render(request, 'paghe/contratti_list.html', context)

# 2. RICERCA GLOBALE AJAX
def global_search_view(request):
    query = request.GET.get('q', '').strip()
    results = []
    if len(query) > 2:
        # Ricerca nei Datori
        datori = DatoreLavoro.objects.filter(Q(nome_cognome__icontains=query) | Q(codice_fiscale__icontains=query))[:5]
        for d in datori:
            results.append({
                'titolo': d.nome_cognome,
                'sottotitolo': f"Datore | {d.codice_fiscale}",
                'icona': 'bi-person-badge',
                'modale_url': f"/ajax/modifica-datore/{d.pk}/",
                'modale_titolo': 'Modifica Datore'
            })
        # Ricerca nei Lavoratori
        lavoratori = Lavoratore.objects.filter(Q(nome_cognome__icontains=query) | Q(codice_fiscale__icontains=query))[:5]
        for l in lavoratori:
            results.append({
                'titolo': l.nome_cognome,
                'sottotitolo': f"Lavoratore | {l.codice_fiscale}",
                'icona': 'bi-person-workspace',
                'modale_url': f"/ajax/modifica-lavoratore/{l.pk}/",
                'modale_titolo': 'Modifica Lavoratore'
            })
        # Ricerca nei Beneficiari
        beneficiari = Beneficiario.objects.filter(Q(nome_cognome__icontains=query) | Q(codice_fiscale__icontains=query))[:5]
        for b in beneficiari:
            results.append({
                'titolo': b.nome_cognome,
                'sottotitolo': f"Beneficiario | {b.codice_fiscale}",
                'icona': 'bi-person-heart',
                'modale_url': f"/ajax/modifica-beneficiario/{b.pk}/",
                'modale_titolo': 'Modifica Beneficiario'
            })
        # Ricerca nei Contratti
        contratti = ContrattoLavoro.objects.filter(
            Q(datore__nome_cognome__icontains=query) |
            Q(lavoratore__nome_cognome__icontains=query) |
            Q(codice_rapporto_inps__icontains=query)
        ).distinct()[:5]
        for c in contratti:
            results.append({
                'titolo': f"{c.datore.nome_cognome} -> {c.lavoratore.nome_cognome}",
                'sottotitolo': f"Contratto | {c.get_tipo_contratto_display()}",
                'icona': 'bi-file-earmark-text',
                'modale_url': f"/ajax/modifica-contratto/{c.pk}/",
                'modale_titolo': 'Modifica Contratto'
            })
    return JsonResponse({'results': results})

# 3. FUNZIONE GENERICA PER FORM AJAX (Per evitare ripetizioni)
def handle_ajax_form(request, form_class, template_name):
    model_type = form_class._meta.model.__name__
    ctx = {'form': None, 'entity_type': model_type}
    if request.method == 'POST':
        form = form_class(request.POST, request.FILES)
        ctx['form'] = form
        if form.is_valid():
            form.save()
            return JsonResponse({'success': True})
        html = render_to_string(template_name, ctx, request=request)
        return JsonResponse({'success': False, 'html': html})
    else:
        ctx['form'] = form_class()
        html = render_to_string(template_name, ctx, request=request)
        return JsonResponse({'success': True, 'html': html})

# Scorciatoie per i vari form
